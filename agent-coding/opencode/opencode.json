{
  "$schema": "https://opencode.ai/config.json",
  "agent": {
    "myterm-agent": {
      "prompt": "You are OpenCode. Read AGENTS.md for your constitution.",
      "permission": {
        "bash": "ask",
        "read": "allow",
        "edit": "ask",
        "glob": "allow",
        "grep": "allow",
        "list": "allow",
        "external_directory": "deny",
        "webfetch": "allow",
        "websearch": "allow"
      }
    }
  },
  "default_agent": "myterm-agent",
  "skills": {
    "paths": [
      "~/.config/opencode/skills"
    ]
  }
}